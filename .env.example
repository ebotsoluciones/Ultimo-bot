# ── Modo ──────────────────────────────────────────────────────────────────────
# true  = cualquiera puede escribir "adm" para entrar al panel
# false = solo los números en ADMINS entran al panel automáticamente
MODO_TEST=true

# ── Admins (separados por coma, formato Twilio) ───────────────────────────────
ADMINS=whatsapp:+5491100000000,whatsapp:+5491199999999

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Storage ───────────────────────────────────────────────────────────────────
# memory   →  RAM (se pierde al reiniciar, ideal para pruebas)
# postgres →  PostgreSQL persistente (recomendado para producción)
# file     →  JSON en disco (solo local)
STORAGE_BACKEND=memory

# Si usás postgres, Railway lo agrega automáticamente al conectar el plugin:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
